<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ITGBrands.CSFT.Login" 
             NavigationPage.HasNavigationBar="False"
             Title="">
    <ContentPage.Content>
        <StackLayout VerticalOptions="Center" HorizontalOptions="CenterAndExpand" Spacing="20">
            <!-- App Logo or Title -->
            <Image Source="logo.png" 
           HeightRequest="100"
           HorizontalOptions="Center" />


            <!-- Barcode Entry -->
            <Frame Padding="3" BackgroundColor="{Binding BlendBorderColor}" >

                <Entry x:Name="BarcodeEntry" Placeholder="Scan Barcode"  Text="7H1149476498763"
           FontSize="20"
           Keyboard="Numeric"
           HorizontalOptions="FillAndExpand"
          
          />
            </Frame>

            <!-- Login Button -->
            <Button Text="Login" 
            FontSize="18"
            BackgroundColor="#007ACC"
            TextColor="White"
            CornerRadius="25"
            HorizontalOptions="FillAndExpand"
            Clicked="OnLoginButtonClicked"
            IsEnabled="True"/>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>